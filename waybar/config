{
  "layer": "top",
  "position": "top",
  "margin-bottom": 0,
  "modules-left": [
    "clock",
    "hyprland/workspaces",
  ],
  "modules-center": [
    "hyprland/window",
  ],
  "modules-right": [
    "temperature",
    "memory",
    "cpu",
    "pulseaudio",
  ],
  "hyprland/window": {
    "format": " {}",
    "separate-outputs": false
  },
  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "active": "",
      "default": ""
    }
  },
  "temperature": {
    "format": "{icon} {temperatureC}°C",
    "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
    "critical-threshold": 80,
    "format-icons": ["", "", ""]
  },
  "memory": {
    "format": " {}%",
    "tooltip": "false"
  },
  "cpu": {
    "format": " {usage}%",
    "tooltip": "false"
  },
  "pulseaudio": {
    "format": "{volume}% {icon}",
    "format-bluetooth": "{volume}% {icon}",
    "format-muted": "",
    "format-icons": {
      "headphone": "",
      "default": ["", ""]
    },
    "scroll-step": 1
  },
  "clock": {
    "format": "{:%H:%M}",
    "interval": 60
  }
}
